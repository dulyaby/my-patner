{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account for business owner, manager, or cashier.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "manager", "cashier"] },
        "businessId": { "type": "string", "description": "ID of the business this user belongs to" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "businessId"]
    },
    "Business": {
      "title": "Business",
      "description": "Business profile information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerUid": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "managerPin": { "type": "string", "description": "4-digit PIN for sensitive actions" },
        "lastSaleNumber": { "type": "integer", "description": "Last sequential sale number used" }
      },
      "required": ["name", "ownerUid"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory item.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "costPrice": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" },
        "lowStockThreshold": { "type": "number", "description": "Alert threshold for low stock" },
        "businessId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "businessId"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Transaction record.",
      "type": "object",
      "properties": {
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "discount": { "type": "number" },
        "netTotal": { "type": "number" },
        "cashierId": { "type": "string" },
        "businessId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isVoided": { "type": "boolean" },
        "saleNumber": { "type": "integer", "description": "Sequential sale number" }
      },
      "required": ["items", "total", "netTotal", "cashierId", "businessId", "timestamp"]
    },
    "VoidLog": {
      "title": "Void Log",
      "description": "Log of items removed from cart before checkout.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "cashierId": { "type": "string" },
        "businessId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" }
      },
      "required": ["productId", "cashierId", "businessId", "timestamp"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier information and debt management.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "debtAmount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" },
        "businessId": { "type": "string" }
      },
      "required": ["name", "businessId"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expenses (rent, salaries, etc.).",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "businessId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["description", "amount", "businessId", "timestamp"]
    },
    "Adjustment": {
      "title": "Adjustment",
      "description": "Adjustment to a previous sale (return, error, discount).",
      "type": "object",
      "properties": {
        "saleId": { "type": "string" },
        "businessId": { "type": "string" },
        "amount": { "type": "number" },
        "reason": { "type": "string", "enum": ["return", "error", "discount", "other"] },
        "note": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "items": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["saleId", "businessId", "amount", "reason", "userId", "createdAt"]
    },
    "stockAdjustments": {
      "title": "Stock Adjustment",
      "description": "Records manual stock changes",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "previousStock": { "type": "number" },
        "newStock": { "type": "number" },
        "difference": { "type": "number" },
        "reason": { "type": "string", "enum": ["correction", "damage", "found", "expired", "other"] },
        "note": { "type": "string" },
        "userId": { "type": "string" },
        "businessId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "productName", "previousStock", "newStock", "difference", "reason", "userId", "businessId", "timestamp"]
    }
  },
  "firestore": {
    "/stockAdjustments/{adjustmentId}": {
      "schema": { "$ref": "#/entities/stockAdjustments" },
      "description": "Collection of manual stock adjustments"
    },
    "/businesses/{businessId}": { "schema": "Business", "description": "Business profiles" },
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Inventory items" },
    "/sales/{saleId}": { "schema": "Sale", "description": "Sales transactions" },
    "/voidLogs/{logId}": { "schema": "VoidLog", "description": "Anti-theft logs" },
    "/suppliers/{supplierId}": { "schema": "Supplier", "description": "Supplier debts" },
    "/expenses/{expenseId}": { "schema": "Expense", "description": "Business expenses" },
    "/adjustments/{adjustmentId}": { "schema": "Adjustment", "description": "Sale adjustments" }
  }
}
